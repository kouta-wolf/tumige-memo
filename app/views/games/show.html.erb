<div class="flex">
  <%= render 'shared/sidebar' %>
  <div class="flex flex-col">
    <div class="text-lg">
      <p><%= "名前：#{@user.name} ゲーム登録数：#{@user.games.count}個" %></p>
    </div>
    <div>
      <table class="border-collapse border border-slate-500">
        <thead>
          <tr>
            <th class="border border-slate-600">タイトル</th>
            <th class="border border-slate-600">リリース日</th>
          </tr> 
        </thead>
        <tbody>
          <% @user_games.each do |user_game| %>
            <tr>
              <td class="border border-slate-600"><%= user_game.game.title %></td>
              <td class="border border-slate-600"><%= user_game.game.release_date %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>



