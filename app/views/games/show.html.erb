<p>ログインしました</p>
<div class="flex">

<%# サイドバー %>
<div class="flex h-screen w-16 flex-col justify-between border-e border-gray-100 bg-white">
  <div>
    <%# アイコン %>
    <div class="inline-flex size-16 items-center justify-center">
      <span class="grid size-10 place-content-center rounded-lg bg-gray-100 text-xl text-gray-600">
        🌞
      </span>
    </div>

    <div class="border-t border-gray-100">
      <div class="px-2">
        <ul class="space-y-1 border-t border-gray-100 pt-4">
          <%= render 'shared/sidebar_link', path: '#', label: 'Dashboard', icon_path: 'dashboard' %>
          <%= render 'shared/sidebar_link', path: '#', label: 'Library', icon_path: 'library' %>
          <%= render 'shared/sidebar_link', path: '#', label: 'List', icon_path: 'list' %>
          <%= render 'shared/sidebar_link', path: '#', label: 'Settings', icon_path: 'settings' %>
        </ul>
      </div>
    </div>
  </div>

  <div class="sticky inset-x-0 bottom-0 border-t border-gray-100 bg-white p-2">
    <%= render 'shared/sidebar_function', path: '#', label: 'Logout', icon_path: 'logout' %>
  </div>
</div>

  <div class="flex flex-col">
    <div class="text-lg">
      <p><%= p "名前：#{@user.name} ゲーム登録数：#{@user.games.count}個" %></p>
    </div>
    <div>
      <table class="border-collapse border border-slate-500">
        <thead>
          <tr>
            <th class="border border-slate-600">タイトル</th>
            <th class="border border-slate-600">リリース日</th>
          </tr> 
        </thead>
        <tbody>
          <% @user_games.each do |user_game| %>
            <tr>
              <td class="border border-slate-600"><%= user_game.game.title %></td>
              <td class="border border-slate-600"><%= user_game.game.release_date %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>



